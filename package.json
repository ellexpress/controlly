{
  "name": "@ellexpress/controlly",
  "version": "0.0.2",
  "description": "Middleware para Express que facilita la gestión de transacciones con Sequelize y el manejo centralizado de errores, incluyendo notificaciones por correo en producción.",
  "main": "dist/controlly.cjs",
  "module": "dist/controlly.mjs",
  "type": "module",
  "exports": {
    "import": "./dist/controlly.mjs",
    "require": "./dist/controlly.cjs"
  },
  "scripts": {
    "test": "node test/controller.cjs",
    "build": "rollup -c",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ellexpress/controlly.git"
  },
  "keywords": [
    "controller",
    "transactions",
    "exception",
    "email",
    "exception",
    "exceptions"
  ],
  "author": "Cristian Emanuelle Guzmán Suárez",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ellexpress/controlly/issues"
  },
  "homepage": "https://github.com/ellexpress/controlly#readme",
  "dependencies": {
    "@ellenode/faily": "^0.0.3",
    "@ellenode/maily": "^1.0.6"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "rollup": "^4.45.0"
  }
}
